{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kgx.dev/schemas/kgpack-manifest.schema.json",
  "title": "KG Pack manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "version", "kind", "pack_id", "created_at"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable pack name."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version MAJOR.MINOR.PATCH (numeric segments only)."
    },
    "kind": {
      "type": "string",
      "enum": ["vendor_core", "overlay", "workload"],
      "description": "Pack classification for immutability and composition rules."
    },
    "pack_id": {
      "type": "string",
      "format": "uri",
      "description": "Stable URI identifying this pack."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 / RFC 3339 timestamp of pack creation."
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[^:]+:.+@[0-9]+\\.[0-9]+\\.[0-9]+$"
      },
      "uniqueItems": true,
      "description": "List of upstream pack_id@version dependency strings."
    },
    "documents_root": {
      "type": "string",
      "default": "documents/",
      "description": "Relative path to document root; default documents/ when omitted by tooling."
    }
  }
}
